{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Insider One Notification Gateway",
  "port": 8000,
  "timeout": "30s",
  "extra_config": {
    "router": {
      "return_error_msg": true
    },
    "qos/ratelimit/service": {
      "max_rate": 500,
      "capacity": 500,
      "every": "1s"
    },
    "telemetry/opentelemetry": {
      "service_name": "insider-krakend",
      "trace_sample_rate": 1.0,
      "exporters": {
        "otlp": [
          {
            "host": "jaeger",
            "port": 4318,
            "use_http": true
          }
        ]
      },
      "layers": {
        "global": { "report_headers": true },
        "proxy": { "report_headers": true },
        "backend": { "report_headers": true }
      }
    },
    "modifier/martian": {
      "header.Id": {
        "scope": ["request"],
        "name": "X-Trace-Id"
      }
    }
  },
  "endpoints": [
    {
      "endpoint": "/api/v1/notifications",
      "method": "POST",
      "input_headers": ["Content-Type", "X-Trace-Id", "X-Idempotency-Key", "Traceparent", "Tracestate"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications",
          "host": ["http://api:8080"],
          "method": "POST"
        }
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 200,
          "capacity": 200,
          "every": "1s"
        }
      }
    },
    {
      "endpoint": "/api/v1/notifications/batch",
      "method": "POST",
      "input_headers": ["Content-Type", "X-Trace-Id", "Traceparent", "Tracestate"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications/batch",
          "host": ["http://api:8080"],
          "method": "POST"
        }
      ]
    },
    {
      "endpoint": "/api/v1/notifications/{id}",
      "method": "GET",
      "input_headers": ["X-Trace-Id", "Traceparent", "Tracestate"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications/{id}",
          "host": ["http://api:8080"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/notifications/{id}",
      "method": "DELETE",
      "input_headers": ["X-Trace-Id", "Traceparent", "Tracestate"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications/{id}",
          "host": ["http://api:8080"],
          "method": "DELETE"
        }
      ]
    },
    {
      "endpoint": "/api/v1/notifications/batch/{batchId}",
      "method": "GET",
      "input_headers": ["X-Trace-Id", "Traceparent", "Tracestate"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications/batch/{batchId}",
          "host": ["http://api:8080"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/notifications",
      "method": "GET",
      "input_headers": ["X-Trace-Id", "Traceparent", "Tracestate"],
      "input_query_strings": ["status", "channel", "from_date", "to_date", "page", "page_size"],
      "backend": [
        {
          "url_pattern": "/api/v1/notifications",
          "host": ["http://api:8080"]
        }
      ]
    },
    {
      "endpoint": "/api/v1/health",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/v1/health",
          "host": ["http://api:8080"]
        }
      ]
    }
  ]
}
