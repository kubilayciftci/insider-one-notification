{
  "title": "Insider One Notifications",
  "uid": "insider-notifications",
  "panels": [
    {
      "title": "Notifications Created (by channel)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(notifications_created_total[1m])", "legendFormat": "{{channel}} / {{priority}}" }]
    },
    {
      "title": "Delivery Success vs Failure",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(notifications_delivered_total[1m])", "legendFormat": "delivered {{channel}}" },
        { "expr": "rate(notifications_failed_total[1m])", "legendFormat": "failed {{channel}}" }
      ]
    },
    {
      "title": "Delivery Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(notification_delivery_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{channel}}" }]
    },
    {
      "title": "Retry Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "rate(notifications_retried_total[1m])", "legendFormat": "retries {{channel}}" }]
    },
    {
      "title": "HTTP Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "{{method}} {{path}}" }]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s"
}
